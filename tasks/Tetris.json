{
    "task": [
        {
            "name": "TETROMINOES",
            "entry": "TetrisEntrance",
            "description": "<font color='red'>In this task, the in-game board is managed entirely by the internal AI, rather than by capturing screenshots. Please do not interact with the game screen while running this task to ensure that the AI’s decisions align with the actual game state.</font>",
            "option": [
                "TetrisAutoRepeat_Single",
                "TetrisAllowSpeedDrop"
            ]
        }
    ],
    "option": {
        "TetrisAutoRepeat_Single": {
            "type": "switch",
            "label": "Auto combo",
            "description": "When enabled, the game will automatically repeat multiple rounds; when disabled, only one round will be performed",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "option": [
                        "TetrisConsumeAllVitality_Single"
                    ],
                    "pipeline_override": {
                        "TetrisHandleGameActive": {
                            "custom_action_param": {
                                "mode": "single"
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "TetrisHandleGameActive": {
                            "custom_action_param": {
                                "mode": "single",
                                "use_all_vitality": false,
                                "repeat_count": 1
                            },
                            "on_error": ["TetrisExit"]
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "TetrisConsumeAllVitality_Single": {
            "type": "switch",
            "label": "Consume All City Stamina",
            "description": "When enabled, the system will automatically detect City Stamina levels and stop automatically when City Stamina is depleted; when disabled, it will repeat for the specified number of rounds specified number of rounds",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "pipeline_override": {
                        "TetrisHandleGameActive": {
                            "custom_action_param": {
                                "mode": "single",
                                "use_all_vitality": true
                            },
                            "next": [
                                "[JumpBack]TetrisCheckVitality",
                                "TetrisExit"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off",
                    "option": [
                        "TetrisRepeatCount_Single"
                    ],
                    "pipeline_override": {
                        "TetrisHandleGameActive": {
                            "custom_action_param": {
                                "mode": "single",
                                "use_all_vitality": false
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "TetrisRepeatCount_Single": {
            "type": "input",
            "label": "Auto-combo cycles",
            "description": "Number of auto-combo cycles",
            "inputs": [
                {
                    "name": "repeat_count",
                    "label": "cycles",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "TetrisHandleGameActive": {
                    "custom_action_param": {
                        "mode": "single",
                        "use_all_vitality": false,
                        "repeat_count": "{repeat_count}"
                    },
                    "on_error": [
                        "TetrisExit"
                    ]
                }
            }
        },
        "TetrisAllowSpeedDrop": {
            "type": "switch",
            "label": "Allow Speed Drop",
            "description": "When enabled, blocks will automatically drop at a faster rate after translation/rotation",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "pipeline_override": {
                        "TetrisEntrance": {
                            "custom_action_param": {
                                "allow_speed_drop": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off"
                }
            ],
            "default_case": "No"
        }
    }
}
