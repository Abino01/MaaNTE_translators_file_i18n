{
    "task": [
        {
            "name": "Super Sound",
            "entry": "RhythmEntrance",
            "option": [
                "自动选曲",
                "自动连打",
                "目标帧率"
            ]
        }
    ],
    "option": {
        "自动选曲": {
            "type": "switch",
            "label": "Auto choose song",
            "description": "When enabled, the song will be automatically selected (Mayoiuta); when disabled, the target song will be manually specified",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "auto_select": true,
                                "song_name": ""
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off",
                    "option": [
                        "Selection of Songs for Performance"
                    ]
                }
            ],
            "default_case": "No"
        },
        "演奏目标歌曲选择": {
            "type": "select",
            "label": "Target Song",
            "description": "Select the song you want to play",
            "cases": [
                {
                    "name": "Heroic_Appearance",
                    "label": "Heroic_Appearance",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Heroic_Appearance"
                            }
                        }
                    }
                },
                {
                    "name": "Destiny",
                    "label": "Destiny",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Destiny"
                            }
                        }
                    }
                },
                {
                    "name": "Everlasting_Dazing_Summer_Short",
                    "label": "Everlasting_Dazing_Summer(Short_Ver.)",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Everlasting_Dazing_Summer(Short_Ver.)"
                            }
                        }
                    }
                },
                {
                    "name": "Everlasting_Dazing_Summer",
                    "label": "Everlasting_Dazing_Summer",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Everlasting_Dazing_Summer"
                            }
                        }
                    }
                },
                {
                    "name": "Mayoiuta",
                    "label": "Mayoiuta",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Mayoiuta"
                            }
                        }
                    }
                }
            ],
            "default_case": "Heroic_Appearance"
        },
        "自动连打": {
            "type": "switch",
            "label": "Auto-combo",
            "description": "When enabled, the song will be run at auto-combo to played; when disabled, it will be played once",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "option": [
                        "Auto-combo mode"
                    ]
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "RhythmRepeatCheck": {
                            "custom_action_param": {
                                "auto_repeat_count": 0,
                                "auto_repeat_max": false
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "连打模式": {
            "type": "switch",
            "label": "Auto-combo until have no any City Stamina",
            "description": "When enabled, the song will be auto-combo until have no any City Stamina; when disabled, the auto-combo times will be determined by the option of Auto-combo times",
            "cases": [
                {
                    "name": "Yes",
                    "label": "Max",
                    "pipeline_override": {
                        "RhythmRepeatCheck": {
                            "custom_action_param": {
                                "auto_repeat_max": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "Fixed times",
                    "option": [
                        "Auto-combo times"
                    ]
                }
            ],
            "default_case": "No"
        },
        "连打次数": {
            "type": "input",
            "label": "Auto-combo times",
            "description": "Auto-combo times",
            "inputs": [
                {
                    "name": "auto_repeat_count",
                    "label": "times",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RhythmRepeatCheck": {
                    "custom_action_param": {
                        "auto_repeat_count": "{auto_repeat_count}",
                        "auto_repeat_max": false
                    }
                }
            }
        },
        "目标帧率": {
            "type": "input",
            "label": "Target FPS",
            "description": "The frame rate of the performance loop, recommended 30~120",
            "inputs": [
                {
                    "name": "target_fps",
                    "label": "FPS",
                    "default": "60",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RhythmPlaying": {
                    "custom_action_param": {
                        "target_fps": "{target_fps}"
                    }
                }
            }
        }
    }
}