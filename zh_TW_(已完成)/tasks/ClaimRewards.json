{
    "task": [
        {
            "name": "領取獎勵",
            "entry": "ClaimRewardsEntrance",
            "description": "自動領取活耀度/環期賞令的獎勵。",
            "controller": [
                "Win32",
                "Win32-Front"
            ],
            "option": [
                "ClaimRewardsActivity",
                "ClaimRewardsBattlePass"
            ]
        }
    ],
    "option": {
        "ClaimRewardsActivity": {
            "type": "switch",
            "label": "領取活躍度獎勵",
            "cases": [
                {
                    "name": "Yes",
                    "label": "啟用",
                    "pipeline_override": {
                        "ClaimRewardsActivity": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "ClaimRewardsActivity": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "ClaimRewardsBattlePass": {
            "type": "switch",
            "label": "領取環期賞令獎勵",
            "cases": [
                {
                    "name": "Yes",
                    "label": "啟用",
                    "pipeline_override": {
                        "ClaimRewardsBattlePass": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "ClaimRewardsBattlePass": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}
