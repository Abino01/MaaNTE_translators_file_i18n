{
  "task": [
    {
      "name": "AutoPiano",
      "label": "自動演奏ピアノ",
      "description": "MIDI楽譜を読み込み、現在のターゲットウィンドウにキーボード演奏データを送信する。",
      "entry": "AutoPiano",
      "default_check": false,
      "option": [
        "MidiScoreFile"
      ]
    }
  ],
  "option": {
    "MidiScoreFile": {
      "label": "MIDI 楽譜",
      "type": "select",
      "default_case": "MidiScoreFile_Custom",
      "cases": [
        {
          "name": "MidiScoreFile_Custom",
          "label": "カスタムパス",
          "option": [
            "MidiSettings_Custom"
          ]
        }
      ]
    },
    "MidiSettings_Custom": {
      "label": "MIDI 楽譜 カスタムパス",
      "type": "input",
      "inputs": [
        {
          "name": "SongPath",
          "label": "楽譜パス",
          "description": "相対パスはプロジェクトのルートディレクトリから解決されます（例：songs/example.mid）。絶対パスを指定することも可能です。。",
          "default": "songs/example.mid",
          "pipeline_type": "string",
          "verify": "^.+\\.(mid|midi)$",
          "pattern_msg": ".mid / .midi ファイルのパスを入力してください。"
        },
        {
          "name": "Speed",
          "label": "再生速度",
          "default": "1.0",
          "pipeline_type": "string",
          "verify": "^(?:[1-9]\\d*(?:\\.\\d+)?|0\\.\\d+)$",
          "pattern_msg": "0より大きい数値を入力してください。例：1.0 または 1.25。"
        },
        {
          "name": "Transpose",
          "label": "転調",
          "default": "0",
          "pipeline_type": "string",
          "verify": "^-?\\d+$",
          "pattern_msg": "整数の半音数を入力してください、例：-12、0、7。"
        }
      ],
      "pipeline_override": {
        "AutoPiano": {
          "custom_action_param": {
            "song": "{SongPath}",
            "speed": "{Speed}",
            "transpose": "{Transpose}"
          }
        }
      }
    }
  }
}
