{
  "task": [
    {
      "name": "AutoPiano",
      "label": "自動彈琴",
      "description": "讀取.midi曲目並向當前目標視窗發送鍵盤演奏。",
      "entry": "AutoPiano",
      "default_check": false,
      "option": [
        "MidiScoreFile"
      ]
    }
  ],
  "option": {
    "MidiScoreFile": {
      "label": "MIDI曲目",
      "type": "select",
      "default_case": "MidiScoreFile_Custom",
      "cases": [
        {
          "name": "MidiScoreFile_Custom",
          "label": "自定義路徑",
          "option": [
            "MidiSettings_Custom"
          ]
        }
      ]
    },
    "MidiSettings_Custom": {
      "label": "MIDI曲目 自定義路徑",
      "type": "input",
      "inputs": [
        {
          "name": "SongPath",
          "label": "曲目路徑",
          "description": "相對路徑會從項目根目錄解析，例如 songs/example.mid；也可以填寫絕對路徑。",
          "default": "songs/example.mid",
          "pipeline_type": "string",
          "verify": "^.+\\.(mid|midi)$",
          "pattern_msg": "請輸入 .mid / .midi 文件路徑。"
        },
        {
          "name": "Speed",
          "label": "播放速度",
          "default": "1.0",
          "pipeline_type": "string",
          "verify": "^(?:[1-9]\\d*(?:\\.\\d+)?|0\\.\\d+)$",
          "pattern_msg": "請輸入大於 0 的數字，例如 1.0 或 1.25。"
        },
        {
          "name": "Transpose",
          "label": "轉調",
          "default": "0",
          "pipeline_type": "string",
          "verify": "^-?\\d+$",
          "pattern_msg": "請輸入整數半音數，例如 -12、0、7。"
        }
      ],
      "pipeline_override": {
        "AutoPiano": {
          "custom_action_param": {
            "song": "{SongPath}",
            "speed": "{Speed}",
            "transpose": "{Transpose}"
          }
        }
      }
    }
  }
}
