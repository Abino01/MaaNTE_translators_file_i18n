{
    "task": [
        {
            "name": "實時輔助",
            "entry": "RealTimeTaskMain",
            "description": "實時輔助小工具，需要<br><span style='color:red'>“桌面端-前台”</span><br>控制器",
            "option": [
                "RealTimeCheckInterval",
                "RealTimeAutoSkipStory",
                "RealTimeAutoTeleport"
            ],
            "controller": [
                "Win32-Front"
            ]
        }
    ],
    "option": {
        "RealTimeCheckInterval": {
            "type": "input",
            "label": "檢測間隔 (ms)",
            "description": "兩次檢測之間的間隔，單位毫秒",
            "inputs": [
                {
                    "name": "interval",
                    "default": "500",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RealTimeSleep": {
                    "post_delay": "{interval}"
                }
            }
        },
        "RealTimeAutoSkipStory": {
            "type": "switch",
            "label": "自動劇情",
            "description": "自動點擊跳過劇情按鈕",
            "cases": [
                {
                    "name": "Yes",
                    "label": "開啟",
                    "option": [
                        "RealTimeAutoSkipStoryDialog"
                    ],
                    "pipeline_override": {
                        "RealTimeSkipStory": {
                            "enabled": true
                        },
                        "RealTimeSkipStoryDialogConfirm": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "關閉",
                    "pipeline_override": {
                        "RealTimeSkipStory": {
                            "enabled": false
                        },
                        "RealTimeSkipStoryDialog": {
                            "enabled": false
                        },
                        "RealTimeSkipStoryDialogConfirm": {
                            "enabled": false
                        },
                        "RealTimeSkipStoryDialogCheckbox": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoSkipStoryDialog": {
            "type": "switch",
            "label": "自動勾選“今日不再提示”",
            "description": "在跳過劇情彈窗中，自動勾選“今日不再提示”，避免每次彈出確認",
            "cases": [
                {
                    "name": "Yes",
                    "label": "啟用",
                    "pipeline_override": {
                        "RealTimeSkipStoryDialogCheckbox": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "RealTimeSkipStoryDialogCheckbox": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleport": {
            "type": "switch",
            "label": "自動傳送",
            "description": "檢測到特定傳送點時自動點擊傳送",
            "cases": [
                {
                    "name": "Yes",
                    "label": "開啟",
                    "option": [
                        "RealTimeAutoTeleportWitte",
                        "RealTimeAutoTeleportPhone"
                    ]
                },
                {
                    "name": "No",
                    "label": "關閉",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "RealTimeAutoTeleportWitte": {
            "type": "switch",
            "label": "維特海默塔",
            "description": "是否檢測維特海默塔的傳送點",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleportPhone": {
            "type": "switch",
            "label": "ReroRero電話亭",
            "description": "是否檢測ReroRero電話亭的傳送點",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}
