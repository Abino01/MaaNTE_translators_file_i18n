{
    "task": [
        {
            "name": "超强音",
            "entry": "RhythmEntrance",
            "option": [
                "自动选曲",
                "自动连打",
                "目标帧率"
            ]
        }
    ],
    "option": {
        "自动选曲": {
            "type": "switch",
            "label": "自动选曲",
            "description": "启用后自动选择歌曲（迷星叫），关闭则手动指定目标歌曲",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "auto_select": true,
                                "song_name": ""
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "option": [
                        "演奏目标歌曲选择"
                    ]
                }
            ],
            "default_case": "No"
        },
        "演奏目标歌曲选择": {
            "type": "select",
            "label": "目标歌曲",
            "description": "选择要演奏的歌曲",
            "cases": [
                {
                    "name": "Heroic_Appearance",
                    "label": "Heroic_Appearance",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Heroic_Appearance"
                            }
                        }
                    }
                },
                {
                    "name": "Destiny",
                    "label": "Destiny",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Destiny"
                            }
                        }
                    }
                },
                {
                    "name": "Everlasting_Dazing_Summer_Short",
                    "label": "Everlasting_Dazing_Summer(Short_Ver.)",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Everlasting_Dazing_Summer(Short_Ver.)"
                            }
                        }
                    }
                },
                {
                    "name": "Everlasting_Dazing_Summer",
                    "label": "Everlasting_Dazing_Summer",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "Everlasting_Dazing_Summer"
                            }
                        }
                    }
                },
                {
                    "name": "迷星叫",
                    "label": "迷星叫",
                    "pipeline_override": {
                        "RhythmSelectSong": {
                            "custom_action_param": {
                                "song_name": "迷星叫"
                            }
                        }
                    }
                }
            ],
            "default_case": "Heroic_Appearance"
        },
        "自动连打": {
            "type": "switch",
            "label": "自动连打",
            "description": "启用后连续演奏指定次数，关闭则仅演奏一次",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "option": [
                        "连打模式"
                    ]
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "RhythmRepeatCheck": {
                            "custom_action_param": {
                                "auto_repeat_count": 0,
                                "auto_repeat_max": false
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "连打模式": {
            "type": "switch",
            "label": "连打直到活力耗尽",
            "description": "开启后自动连打直到活力耗尽，关闭则使用固定次数",
            "cases": [
                {
                    "name": "Yes",
                    "label": "Max",
                    "pipeline_override": {
                        "RhythmRepeatCheck": {
                            "custom_action_param": {
                                "auto_repeat_max": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "固定次数",
                    "option": [
                        "连打次数"
                    ]
                }
            ],
            "default_case": "No"
        },
        "连打次数": {
            "type": "input",
            "label": "连打次数",
            "description": "连续演奏的次数",
            "inputs": [
                {
                    "name": "auto_repeat_count",
                    "label": "次数",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RhythmRepeatCheck": {
                    "custom_action_param": {
                        "auto_repeat_count": "{auto_repeat_count}",
                        "auto_repeat_max": false
                    }
                }
            }
        },
        "目标帧率": {
            "type": "input",
            "label": "目标帧率",
            "description": "演奏循环的每秒帧率，建议30~120",
            "inputs": [
                {
                    "name": "target_fps",
                    "label": "FPS",
                    "default": "60",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RhythmPlaying": {
                    "custom_action_param": {
                        "target_fps": "{target_fps}"
                    }
                }
            }
        }
    }
}