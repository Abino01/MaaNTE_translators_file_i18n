{
    "task": [
        {
            "name": "Audio evasion",
            "entry": "SoundDodgeMain",
            "description": "Audio-based automatic evasion and counterattack, require[color:red]“Desktop - Front Desk”[/color]Controller",
            "option": [
                "SoundDodgeEnable",
                "SoundDodgeAllAttacks",
                "SoundDodgeThreshold",
                "SoundCounterThreshold"
            ],
            "controller": [
                "Win32-Front"
            ]
        }
    ],
    "option": {
        "SoundDodgeEnable": {
            "type": "switch",
            "label": "Enable Audio Evasion",
            "description": "When enabled, the system will automatically trigger evasion based on game audio cues",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "pipeline_override": {}
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "enable_sound_trigger": false
                            }
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "SoundDodgeAllAttacks": {
            "type": "switch",
            "label": "Evasion only",
            "description": "When enabled, only evasion will be executed; when disabled, both evasion and counterattack will be executed",
            "cases": [
                {
                    "name": "Yes",
                    "label": "Evasion only",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "dodge_all_attacks": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "Evasion + Counterattack",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "dodge_all_attacks": false
                            }
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "SoundDodgeThreshold": {
            "type": "input",
            "label": "Evasion Threshold",
            "description": "Evasion audio cue recognition threshold, range 0.0-1.0, the lower the more sensitive",
            "inputs": [
                {
                    "name": "threshold",
                    "default": "0.13",
                    "pipeline_type": "string",
                    "verify": "^0\\.\\d+$|^1\\.0*$"
                }
            ],
            "pipeline_override": {
                "SoundDodgeMain": {
                    "custom_action_param": {
                        "threshold": "{threshold}"
                    }
                }
            }
        },
        "SoundCounterThreshold": {
            "type": "input",
            "label": "Counterattack Threshold",
            "description": "Counterattack audio cue recognition threshold, range 0.0-1.0, the lower the more sensitive",
            "inputs": [
                {
                    "name": "counter_threshold",
                    "default": "0.12",
                    "pipeline_type": "string",
                    "verify": "^0\\.\\d+$|^1\\.0*$"
                }
            ],
            "pipeline_override": {
                "SoundDodgeMain": {
                    "custom_action_param": {
                        "counter_attack_threshold": "{counter_threshold}"
                    }
                }
            }
        }
    }
}
