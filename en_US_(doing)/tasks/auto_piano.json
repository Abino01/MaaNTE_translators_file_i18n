{
  "task": [
    {
      "name": "AutoPiano",
      "label": "Automatic Piano Playing",
      "description": "Read MIDI scores and send keyboard playing signals to the current target window.",
      "entry": "AutoPiano",
      "default_check": false,
      "option": [
        "MidiScoreFile"
      ]
    }
  ],
  "option": {
    "MidiScoreFile": {
      "label": "MIDI Scores",
      "type": "select",
      "default_case": "MidiScoreFile_Custom",
      "cases": [
        {
          "name": "MidiScoreFile_Custom",
          "label": "Custom Path",
          "option": [
            "MidiSettings_Custom"
          ]
        }
      ]
    },
    "MidiSettings_Custom": {
      "label": "Custom Path for MIDI Scores",
      "type": "input",
      "inputs": [
        {
          "name": "SongPath",
          "label": "Score Path",
          "description": "Relative paths are resolved from the project root, e.g., songs/example.mid; absolute paths are also accepted.",
          "default": "songs/example.mid",
          "pipeline_type": "string",
          "verify": "^.+\\.(mid|midi)$",
          "pattern_msg": "Please enter a .mid / .midi file path."
        },
        {
          "name": "Speed",
          "label": "Playback Speed",
          "default": "1.0",
          "pipeline_type": "string",
          "verify": "^(?:[1-9]\\d*(?:\\.\\d+)?|0\\.\\d+)$",
          "pattern_msg": "Please enter a number greater than 0, e.g., 1.0 or 1.25."
        },
        {
          "name": "Transpose",
          "label": "Transpose",
          "default": "0",
          "pipeline_type": "string",
          "verify": "^-?\\d+$",
          "pattern_msg": "Please enter an integer number of semitones, e.g., -12, 0, or 7."
        }
      ],
      "pipeline_override": {
        "AutoPiano": {
          "custom_action_param": {
            "song": "{SongPath}",
            "speed": "{Speed}",
            "transpose": "{Transpose}"
          }
        }
      }
    }
  }
}
