{
    "task": [
        {
            "name": "Claim your reward",
            "entry": "ClaimRewardsEntrance", 
            "description": "Auto claim the City Stamina / Circle bounty rewards.。",
            "controller": [
                "Win32",
                "Win32-Front"
            ],
            "option": [
                "ClaimRewardsActivity",
                "ClaimRewardsBattlePass"
            ]
        }
    ],
    "option": {
        "ClaimRewardsActivity": {
            "type": "switch",
            "label": "Claim the City Stamina",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "pipeline_override": {
                        "ClaimRewardsActivity": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "ClaimRewardsActivity": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "ClaimRewardsBattlePass": {
            "type": "switch",
            "label": "Claim Circle Bounty Rewards",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "pipeline_override": {
                        "ClaimRewardsBattlePass": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "ClaimRewardsBattlePass": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}
