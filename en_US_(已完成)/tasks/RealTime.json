{
    "task": [
        {
            "name": "Real-time assistance tools",
            "entry": "RealTimeTaskMain",
            "description": "Real-time assistance tools, requires[color:red]“Desktop - Front Desk”[/color]Controller",
            "option": [
                "RealTimeCheckInterval",
                "RealTimeAutoSkipStory",
                "RealTimeAutoTeleport"
            ],
            "controller": [
                "Win32-Front"
            ]
        }
    ],
    "option": {
        "RealTimeCheckInterval": {
            "type": "input",
            "label": "Testing interval (ms)",
            "description": "The interval between two measurements(ms)",
            "inputs": [
                {
                    "name": "interval",
                    "default": "500",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RealTimeSleep": {
                    "post_delay": "{interval}"
                }
            }
        },
        "RealTimeAutoSkipStory": {
            "type": "switch",
            "label": "Auto Story Skip",
            "description": "Automatically click the skip story button",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "option": [
                        "RealTimeAutoSkipStoryDialog"
                    ],
                    "pipeline_override": {
                        "RealTimeSkipStory": {
                            "enabled": true
                        },
                        "RealTimeSkipStoryDialogConfirm": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "RealTimeSkipStory": {
                            "enabled": false
                        },
                        "RealTimeSkipStoryDialog": {
                            "enabled": false
                        },
                        "RealTimeSkipStoryDialogConfirm": {
                            "enabled": false
                        },
                        "RealTimeSkipStoryDialogCheckbox": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoSkipStoryDialog": {
            "type": "switch",
            "label": "Automatically check “Don't ask me again today”.",
            "description": "In the skip story pop-up, automatically check ‘Don't ask me again today’ to avoid having to confirm every time.",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "pipeline_override": {
                        "RealTimeSkipStoryDialogCheckbox": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "RealTimeSkipStoryDialogCheckbox": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleport": {
            "type": "switch",
            "label": "Automatic Transfer",
            "description": "Detect specific teleportation points and click to teleport automatically",
            "cases": [
                {
                    "name": "Yes",
                    "label": "on",
                    "option": [
                        "RealTimeAutoTeleportWitte",
                        "RealTimeAutoTeleportPhone"
                    ]
                },
                {
                    "name": "No",
                    "label": "off",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "RealTimeAutoTeleportWitte": {
            "type": "switch",
            "label": "Wertheimer Tower",
            "description": "Whether to detect the teleportation points of Wertheimer Tower",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleportPhone": {
            "type": "switch",
            "label": "ReroRero Phone Booth",
            "description": "Whether to detect the teleportation points of ReroRero Phone Booth",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}
